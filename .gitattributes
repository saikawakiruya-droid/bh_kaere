# Enforce LF line endings for all text files so the project builds and runs
# identically in the grading (submission) environment regardless of the
# committer's OS. A CRLF Makefile in particular breaks `make` on Linux.
* text=auto eol=lf

# Binary artifacts must never be line-ending converted.
*.whl     binary
*.tar.gz  binary
*.pdf     binary
*.png     binary
